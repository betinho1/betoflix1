{
  "name": "jellyfin_stripe_gateway_api",
  "version": "1.0.0",
  "type": "module",
  "description": "Jellyfin Stripe Gateway API",
  "main": "index.js",
  "scripts": {
    "start:dev": "tsx --watch src/server.ts",
    "start": "node build/server.js",
    "build": "tsup src/server.ts --format esm --clean --out-dir build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "Henrry-maximo",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "7.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.5.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}